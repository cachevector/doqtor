{
  "name": "@doqtor/cli",
  "version": "0.1.1",
  "type": "module",
  "description": "Keep your docs in sync with your code",
  "bin": {
    "doqtor": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "documentation",
    "drift",
    "docs",
    "typescript",
    "lint"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cachevector/doqtor",
    "directory": "apps/cli"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@doqtor/core-engine": "workspace:*",
    "@doqtor/fixer": "workspace:*",
    "@doqtor/matcher": "workspace:*",
    "@doqtor/parser": "workspace:*",
    "tsup": "^8.0.0"
  }
}
